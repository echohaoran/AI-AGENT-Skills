{
  "spec_version": "2.0",
  "id": "com.awesome-privacy.privacy-shield",
  "name": "Privacy Shield",
  "version": "1.2.0",
  "description": "本地敏感数据脱敏与可逆还原工具 v1.2。读取本地文件，自动检测并脱敏敏感信息，生成可逆映射表。支持 Word/Excel/Markdown 的精准替换脱敏，以及 PDF 的图像级遮盖脱敏（PyMuPDF 坐标精准定位 + 高清渲染 + OCR 验证）。",
  "author": "awesome-privacy-team",
  "license": "MIT",
  "runtime": "python3",
  "capabilities": ["file_system", "terminal"],
  "triggers": {
    "intent": ["脱敏", "隐私保护", "隐私处理", "masking", "redact", "privacy", "敏感数据", "个人信息"],
    "file_ext": [".pdf", ".docx", ".xlsx", ".xls", ".md", ".markdown", ".jpg", ".jpeg", ".png"]
  },
  "entrypoint": "scripts/main.py",
  "supported_formats": ["pdf", "docx", "xlsx", "xls", "md", "markdown", "jpg", "jpeg", "png"],
  "sensitive_types": [
    "NAME", "PHONE", "EMAIL", "ID", "CREDIT_CARD",
    "PASSPORT", "FRAGMENT", "USERNAME",
    "ADDRESS", "IP", "API_KEY", "MONEY", "COMPANY_NAME", "CUSTOM"
  ],
  "redaction_marker": "<<REDACTED_{type}_{index}>>",
  "dependencies": {
    "runtime": [
      "pypdf>=4.0.0",
      "openpyxl>=3.1.0",
      "python-docx>=1.1.0",
      "Pillow>=10.0.0",
      "pytesseract>=0.3.10",
      "PyMuPDF>=1.23.0"
    ]
  }
}
