{
  "spec_version": "2.0",
  "id": "com.awesome-privacy.privacy-shield",
  "name": "Privacy Shield",
  "version": "1.3.0",
  "description": "本地敏感数据脱敏与可逆还原工具 v1.3 — 多格式全管道脱敏。PDF/图片优先 OCR 识别脱敏，自动转换为 Word + Markdown 二次脱敏。输出脱敏版 PDF/DOCX/MD + 汇总映射表 + 反脱敏指南。支持 17 种敏感数据类型。",
  "author": "awesome-privacy-team",
  "license": "MIT",
  "runtime": "python3",
  "capabilities": ["file_system", "terminal"],
  "triggers": {
    "intent": [
      "脱敏",
      "隐私保护",
      "隐私处理",
      "敏感数据",
      "个人信息",
      "打成马赛克",
      "打码",
      "遮盖敏感数据",
      "隐去敏感信息",
      "擦除隐私",
      "保护隐私",
      "去隐私",
      "替换敏感信息",
      "masking",
      "redact",
      "redaction",
      "redact_file",
      "privacy",
      "personal data",
      "PII",
      "personally identifiable",
      "sensitive data",
      "data masking",
      "data redaction",
      "信息脱敏",
      "数据脱敏",
      "文档脱敏",
      "PDF脱敏",
      "图片脱敏",
      "文件脱敏",
      "批处理脱敏",
      "批量脱敏",
      "脱敏处理",
      "隐私合规",
      "合规脱敏",
      "隐去姓名",
      "隐去手机",
      "隐去电话",
      "隐去身份证",
      "隐去地址",
      "隐去邮箱",
      "隐去银行卡",
      "隐藏敏感内容",
      "隐藏隐私",
      "unmask",
      "deidentify",
      "deidentification",
      "anonymize",
      "anonymization",
      "逆脱敏",
      "还原脱敏",
      "反脱敏",
      "脱敏还原",
      "恢复脱敏数据",
      "unredact",
      "restore redacted",
      "脱敏版",
      "脱敏后",
      "脱敏文件",
      "脱敏结果",
      "敏感信息处理"
    ],
    "file_ext": [
      ".pdf", ".docx", ".xlsx", ".xls", ".md", ".markdown",
      ".jpg", ".jpeg", ".png"
    ]
  },
  "entrypoint": "scripts/main.py",
  "supported_formats": ["pdf", "docx", "xlsx", "xls", "md", "markdown", "jpg", "jpeg", "png"],
  "actions": {
    "redact_multi_format": {
      "description": "全格式脱敏管道 — OCR → 遮盖PDF → Word → Markdown 四条线并行",
      "input": {"file_path": "PDF/图片路径", "keyword_rules": "可选关键词规则表"},
      "output": ["ocr_redacted_txt", "pdf_redacted_pdf", "docx_redacted", "md_redacted", "mapping_file", "unmask_doc"]
    }
  },
  "sensitive_types": [
    "NAME", "PHONE", "EMAIL", "ID", "CREDIT_CARD",
    "PASSPORT", "FRAGMENT", "USERNAME",
    "ADDRESS", "IP", "API_KEY", "MONEY", "COMPANY_NAME", "CUSTOM"
  ],
  "redaction_marker": "<<REDACTED_{type}_{index}>>",
  "dependencies": {
    "runtime": [
      "pypdf>=4.0.0",
      "openpyxl>=3.1.0",
      "python-docx>=1.1.0",
      "Pillow>=10.0.0",
      "pytesseract>=0.3.10",
      "PyMuPDF>=1.23.0",
      "pdf2docx>=0.5.8"
    ]
  }
}
